<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ListenShelf.Desktop.ViewModels"
        x:Class="ListenShelf.Desktop.Views.BookMetadataEditorWindow"
        x:DataType="vm:BookMetadataEditorViewModel"
        Width="780"
        Height="760"
        MinWidth="680"
        MinHeight="560"
        Background="{DynamicResource AppBackgroundBrush}"
        CanResize="True"
        Icon="/Assets/Branding/listenshelf.ico"
        ShowInTaskbar="False"
        Title="Edit audiobook details"
        WindowStartupLocation="CenterOwner">

    <Window.Styles>
        <Style Selector="TextBlock.sectionTitle">
            <Setter Property="FontSize" Value="17" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        </Style>
        <Style Selector="TextBlock.fieldLabel">
            <Setter Property="Margin" Value="1,0,0,4" />
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
        </Style>
        <Style Selector="TextBox.metadataField">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="ComboBox.metadataField">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="AutoCompleteBox.metadataField">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="MaxDropDownHeight" Value="240" />
        </Style>
        <Style Selector="NumericUpDown.metadataField">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
        <Style Selector="CalendarDatePicker.metadataField">
            <Setter Property="Background" Value="{DynamicResource SurfaceRaisedBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CornerRadius" Value="8" />
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0"
                Padding="24,20"
                Background="{DynamicResource HeaderBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <StackPanel Spacing="4">
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="Audiobook details" />
                <TextBlock FontSize="12"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="These details stay on this device. Reuse existing values from the searchable suggestions." />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24" Spacing="16">
                <Border Padding="20"
                        CornerRadius="14"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="3">
                            <TextBlock Classes="sectionTitle" Text="Book" />
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="Information about the underlying written work." />
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="fieldLabel" Text="Title *" />
                                <TextBox Classes="metadataField" Text="{Binding Title}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="fieldLabel" Text="Subtitle" />
                                <TextBox Classes="metadataField" Text="{Binding Subtitle}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock Classes="fieldLabel" Text="Authors" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <AutoCompleteBox Grid.Column="0"
                                                 Classes="metadataField"
                                                 FilterMode="ContainsOrdinal"
                                                 GotFocus="MetadataAutoComplete_OnGotFocus"
                                                 IsTextCompletionEnabled="False"
                                                 ItemsSource="{Binding AuthorSuggestions}"
                                                 MinimumPrefixLength="0"
                                                 Text="{Binding AuthorInput, Mode=TwoWay}"
                                                 PlaceholderText="Type or choose an author" />
                                <Button Grid.Column="1"
                                        Padding="14,7"
                                        VerticalAlignment="Stretch"
                                        Command="{Binding AddAuthorCommand}"
                                        Content="Add" />
                            </Grid>
                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Authors}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MetadataValueItemViewModel">
                                        <Border Margin="0,0,7,7"
                                                Padding="9,4,4,4"
                                                CornerRadius="12"
                                                Background="{DynamicResource AccentSoftBrush}">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Text="{Binding Value}" />
                                                <Button Width="24"
                                                        Height="24"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        Command="{Binding RemoveCommand}"
                                                        Content="×"
                                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                                        ToolTip.Tip="Remove author" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Grid ColumnDefinitions="2*,*,*" ColumnSpacing="14">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="fieldLabel" Text="Series" />
                                <AutoCompleteBox Classes="metadataField"
                                                 FilterMode="ContainsOrdinal"
                                                 GotFocus="MetadataAutoComplete_OnGotFocus"
                                                 IsTextCompletionEnabled="False"
                                                 ItemsSource="{Binding SeriesSuggestions}"
                                                 MinimumPrefixLength="0"
                                                 Text="{Binding SeriesName, Mode=TwoWay}"
                                                 PlaceholderText="Type or choose a series" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="fieldLabel" Text="Series position" />
                                <TextBox Classes="metadataField"
                                         Text="{Binding SeriesPosition}"
                                         PlaceholderText="1 or 1.5" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Classes="fieldLabel" Text="Original year" />
                                <NumericUpDown Classes="metadataField"
                                               FormatString="0"
                                               Increment="1"
                                               Maximum="9999"
                                               Minimum="1000"
                                               Value="{Binding OriginalPublicationYear, Mode=TwoWay}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel>
                            <TextBlock Classes="fieldLabel" Text="Original publisher" />
                            <AutoCompleteBox Classes="metadataField"
                                             FilterMode="ContainsOrdinal"
                                             GotFocus="MetadataAutoComplete_OnGotFocus"
                                             IsTextCompletionEnabled="False"
                                             ItemsSource="{Binding OriginalPublisherSuggestions}"
                                             MinimumPrefixLength="0"
                                             Text="{Binding OriginalPublisher, Mode=TwoWay}"
                                             PlaceholderText="Type or choose a publisher" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Classes="fieldLabel" Text="Genres" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <AutoCompleteBox Grid.Column="0"
                                                 Classes="metadataField"
                                                 FilterMode="ContainsOrdinal"
                                                 GotFocus="MetadataAutoComplete_OnGotFocus"
                                                 IsTextCompletionEnabled="False"
                                                 ItemsSource="{Binding GenreSuggestions}"
                                                 MinimumPrefixLength="0"
                                                 Text="{Binding GenreInput, Mode=TwoWay}"
                                                 PlaceholderText="Type or choose a genre" />
                                <Button Grid.Column="1"
                                        Padding="14,7"
                                        VerticalAlignment="Stretch"
                                        Command="{Binding AddGenreCommand}"
                                        Content="Add" />
                            </Grid>
                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Genres}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MetadataValueItemViewModel">
                                        <Border Margin="0,0,7,7"
                                                Padding="9,4,4,4"
                                                CornerRadius="12"
                                                Background="{DynamicResource AccentSoftBrush}">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Text="{Binding Value}" />
                                                <Button Width="24"
                                                        Height="24"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        Command="{Binding RemoveCommand}"
                                                        Content="×"
                                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                                        ToolTip.Tip="Remove genre" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Classes="fieldLabel" Text="Description" />
                            <TextBox Classes="metadataField"
                                     MinHeight="92"
                                     AcceptsReturn="True"
                                     Text="{Binding Description}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Padding="20"
                        CornerRadius="14"
                        Background="{DynamicResource SurfaceBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="1">
                    <StackPanel Spacing="14">
                        <StackPanel Spacing="3">
                            <TextBlock Classes="sectionTitle" Text="Audiobook edition" />
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="Information specific to this recording and release." />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Classes="fieldLabel" Text="Narrators" />
                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                <AutoCompleteBox Grid.Column="0"
                                                 Classes="metadataField"
                                                 FilterMode="ContainsOrdinal"
                                                 GotFocus="MetadataAutoComplete_OnGotFocus"
                                                 IsTextCompletionEnabled="False"
                                                 ItemsSource="{Binding NarratorSuggestions}"
                                                 MinimumPrefixLength="0"
                                                 Text="{Binding NarratorInput, Mode=TwoWay}"
                                                 PlaceholderText="Type or choose a narrator" />
                                <Button Grid.Column="1"
                                        Padding="14,7"
                                        VerticalAlignment="Stretch"
                                        Command="{Binding AddNarratorCommand}"
                                        Content="Add" />
                            </Grid>
                            <ItemsControl Margin="0,8,0,0" ItemsSource="{Binding Narrators}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:MetadataValueItemViewModel">
                                        <Border Margin="0,0,7,7"
                                                Padding="9,4,4,4"
                                                CornerRadius="12"
                                                Background="{DynamicResource AccentSoftBrush}">
                                            <StackPanel Orientation="Horizontal" Spacing="5">
                                                <TextBlock VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                                           Text="{Binding Value}" />
                                                <Button Width="24"
                                                        Height="24"
                                                        Padding="0"
                                                        Background="Transparent"
                                                        Command="{Binding RemoveCommand}"
                                                        Content="×"
                                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                                        ToolTip.Tip="Remove narrator" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="fieldLabel" Text="Audio publisher" />
                                <AutoCompleteBox Classes="metadataField"
                                                 FilterMode="ContainsOrdinal"
                                                 GotFocus="MetadataAutoComplete_OnGotFocus"
                                                 IsTextCompletionEnabled="False"
                                                 ItemsSource="{Binding AudioPublisherSuggestions}"
                                                 MinimumPrefixLength="0"
                                                 Text="{Binding AudioPublisher, Mode=TwoWay}"
                                                 PlaceholderText="Type or choose a publisher" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="fieldLabel" Text="Audiobook release date" />
                                <CalendarDatePicker Classes="metadataField"
                                                    SelectedDate="{Binding AudiobookReleaseDate}" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="fieldLabel" Text="Edition" />
                                <TextBox Classes="metadataField"
                                         Text="{Binding EditionName}"
                                         PlaceholderText="10th anniversary edition" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="fieldLabel" Text="Abridgement" />
                                <ComboBox Classes="metadataField"
                                          ItemsSource="{Binding AbridgementOptions}"
                                          SelectedItem="{Binding SelectedAbridgement}" />
                            </StackPanel>
                        </Grid>

                        <Grid ColumnDefinitions="*,*,*" ColumnSpacing="14">
                            <StackPanel Grid.Column="0">
                                <TextBlock Classes="fieldLabel" Text="ISBN-10" />
                                <TextBox Classes="metadataField" Text="{Binding Isbn10}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Classes="fieldLabel" Text="ISBN-13" />
                                <TextBox Classes="metadataField" Text="{Binding Isbn13}" />
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Classes="fieldLabel" Text="ASIN" />
                                <TextBox Classes="metadataField" Text="{Binding Asin}" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Width="250" HorizontalAlignment="Left">
                            <TextBlock Classes="fieldLabel" Text="Language" />
                            <AutoCompleteBox Classes="metadataField"
                                             FilterMode="ContainsOrdinal"
                                             GotFocus="MetadataAutoComplete_OnGotFocus"
                                             IsTextCompletionEnabled="False"
                                             ItemsSource="{Binding LanguageSuggestions}"
                                             MinimumPrefixLength="0"
                                             Text="{Binding Language, Mode=TwoWay}"
                                             PlaceholderText="Type or choose a language" />
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Classes="fieldLabel" Text="Edition notes" />
                            <TextBox Classes="metadataField"
                                     MinHeight="72"
                                     AcceptsReturn="True"
                                     Text="{Binding EditionNotes}"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2"
                Padding="24,14"
                Background="{DynamicResource FooterBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="18">
                <TextBlock Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource DangerTextBrush}"
                           IsVisible="{Binding HasError}"
                           Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
                    <Button Padding="18,9"
                            Background="{DynamicResource SurfaceRaisedBrush}"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Click="Cancel_OnClick"
                            Content="Cancel" />
                    <Button Padding="18,9"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource OnAccentBrush}"
                            FontWeight="SemiBold"
                            Click="Save_OnClick"
                            Content="Save details" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
