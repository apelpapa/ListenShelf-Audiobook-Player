<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ListenShelf.Desktop.ViewModels"
             xmlns:components="using:ListenShelf.Desktop.Views.Components"
             x:Class="ListenShelf.Desktop.Views.Sections.LibraryView"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*" RowSpacing="12">
        <Border Grid.Row="0"
                Padding="10"
                CornerRadius="11"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Border Grid.Column="0"
                        Padding="9,5"
                        VerticalAlignment="Center"
                        CornerRadius="8"
                        Background="{DynamicResource AccentSoftBrush}">
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentSoftTextBrush}"
                               Text="{Binding LibraryBookCountText}" />
                </Border>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource AccentTextBrush}"
                           Text="{Binding LibraryStatusMessage}"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="6">
                    <StackPanel Margin="0,0,4,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="7">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="10"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="GROUP BY" />
                        <ComboBox Width="138"
                                  ItemsSource="{Binding LibraryGroupOptions}"
                                  SelectedItem="{Binding SelectedLibraryGroupOption, Mode=TwoWay}">
                            <ComboBox.ItemTemplate>
                                <DataTemplate x:DataType="vm:LibraryGroupOptionViewModel">
                                    <TextBlock Text="{Binding DisplayName}" />
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel Margin="4,0"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="7"
                                IsVisible="{Binding IsLibraryTileView}">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="10"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="TILE SIZE" />
                        <Slider Width="105"
                                Minimum="{Binding MinimumTileWidth}"
                                Maximum="{Binding MaximumTileWidth}"
                                TickFrequency="10"
                                IsSnapToTickEnabled="True"
                                Value="{Binding LibraryTileWidth, Mode=TwoWay}" />
                        <TextBlock MinWidth="38"
                                   VerticalAlignment="Center"
                                   FontSize="10"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="{Binding LibraryTileSizeText}" />
                    </StackPanel>

                    <Button Padding="10,6"
                            Background="{DynamicResource SurfaceRaisedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Command="{Binding ShowLibraryAsListCommand}"
                            ToolTip.Tip="List view">
                        <Grid RowDefinitions="Auto,2" RowSpacing="4">
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                                <TextBlock FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="☰" />
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="List" />
                            </StackPanel>
                            <Border Grid.Row="1"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="1"
                                    IsVisible="{Binding IsLibraryListView}" />
                        </Grid>
                    </Button>

                    <Button Padding="10,6"
                            Background="{DynamicResource SurfaceRaisedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Command="{Binding ShowLibraryAsTilesCommand}"
                            ToolTip.Tip="Tile view">
                        <Grid RowDefinitions="Auto,2" RowSpacing="4">
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                                <TextBlock FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="▦" />
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="Tiles" />
                            </StackPanel>
                            <Border Grid.Row="1"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="1"
                                    IsVisible="{Binding IsLibraryTileView}" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border Padding="36"
                    CornerRadius="20"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    IsVisible="{Binding IsLibraryEmpty}">
                <StackPanel MaxWidth="540"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="13">
                    <Image Width="92"
                           Height="92"
                           Margin="0,0,0,5"
                           Source="/Assets/Branding/listenshelf-1024.png"
                           Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="Add your first audiobooks" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding LibraryEmptyDescription}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <Button Margin="0,8,0,0"
                            Padding="19,10"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource OnAccentBrush}"
                            FontWeight="SemiBold"
                            Command="{Binding AddAudiobooksCommand}"
                            Content="Choose audiobook files"
                            IsEnabled="{Binding CanAddAudiobooks}" />
                </StackPanel>
            </Border>

            <Grid IsVisible="{Binding HasLibraryBooks}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding IsLibraryListView}">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding LibraryGroups}"
                                      IsVisible="{Binding IsLibraryGroupOverviewVisible}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LibraryGroupViewModel">
                                    <components:LibraryGroupStackHeader />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel IsVisible="{Binding IsLibraryGroupDetailVisible}">
                            <components:LibraryGroupDetailHeader />
                            <ItemsControl ItemsSource="{Binding ActiveLibraryGroupBooks}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LibraryBookItemViewModel">
                                        <components:LibraryBookListCard />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding LibraryBooks}"
                                      IsVisible="{Binding IsUngroupedLibraryVisible}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LibraryBookItemViewModel">
                                    <components:LibraryBookListCard />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding IsLibraryTileView}">
                    <StackPanel>
                        <ItemsControl ItemsSource="{Binding LibraryGroups}"
                                      IsVisible="{Binding IsLibraryGroupOverviewVisible}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LibraryGroupViewModel">
                                    <components:LibraryGroupStackTile />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel IsVisible="{Binding IsLibraryGroupDetailVisible}">
                            <components:LibraryGroupDetailHeader />
                            <ItemsControl ItemsSource="{Binding ActiveLibraryGroupBooks}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:LibraryBookItemViewModel">
                                        <components:LibraryBookTileCard />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding LibraryBooks}"
                                      IsVisible="{Binding IsUngroupedLibraryVisible}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel Orientation="Horizontal" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:LibraryBookItemViewModel">
                                    <components:LibraryBookTileCard />
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
