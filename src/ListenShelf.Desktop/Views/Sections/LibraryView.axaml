<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ListenShelf.Desktop.ViewModels"
             x:Class="ListenShelf.Desktop.Views.Sections.LibraryView"
             x:DataType="vm:MainWindowViewModel">
    <Grid RowDefinitions="Auto,*" RowSpacing="12">
        <Border Grid.Row="0"
                Padding="10"
                CornerRadius="11"
                Background="{DynamicResource SurfaceAltBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="12">
                <Border Grid.Column="0"
                        Padding="9,5"
                        VerticalAlignment="Center"
                        CornerRadius="8"
                        Background="{DynamicResource AccentSoftBrush}">
                    <TextBlock FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource AccentSoftTextBrush}"
                               Text="{Binding LibraryBookCountText}" />
                </Border>

                <TextBlock Grid.Column="1"
                           VerticalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource AccentTextBrush}"
                           Text="{Binding LibraryStatusMessage}"
                           TextTrimming="CharacterEllipsis" />

                <StackPanel Grid.Column="2"
                            VerticalAlignment="Center"
                            Orientation="Horizontal"
                            Spacing="6">
                    <Button Padding="10,6"
                            Background="{DynamicResource SurfaceRaisedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Command="{Binding ShowLibraryAsListCommand}"
                            ToolTip.Tip="List view">
                        <Grid RowDefinitions="Auto,2" RowSpacing="4">
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                                <TextBlock FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="☰" />
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="List" />
                            </StackPanel>
                            <Border Grid.Row="1"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="1"
                                    IsVisible="{Binding IsLibraryListView}" />
                        </Grid>
                    </Button>

                    <Button Padding="10,6"
                            Background="{DynamicResource SurfaceRaisedBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            Command="{Binding ShowLibraryAsTilesCommand}"
                            ToolTip.Tip="Tile view">
                        <Grid RowDefinitions="Auto,2" RowSpacing="4">
                            <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="6">
                                <TextBlock FontSize="13"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="▦" />
                                <TextBlock FontSize="11"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="Tiles" />
                            </StackPanel>
                            <Border Grid.Row="1"
                                    Background="{DynamicResource AccentBrush}"
                                    CornerRadius="1"
                                    IsVisible="{Binding IsLibraryTileView}" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Border Padding="36"
                    CornerRadius="20"
                    Background="{DynamicResource SurfaceBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1"
                    IsVisible="{Binding IsLibraryEmpty}">
                <StackPanel MaxWidth="540"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="13">
                    <Image Width="92"
                           Height="92"
                           Margin="0,0,0,5"
                           Source="/Assets/Branding/listenshelf-1024.png"
                           Stretch="Uniform" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="Add your first audiobooks" />
                    <TextBlock HorizontalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding LibraryEmptyDescription}"
                               TextAlignment="Center"
                               TextWrapping="Wrap" />
                    <Button Margin="0,8,0,0"
                            Padding="19,10"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource AccentBrush}"
                            Foreground="{DynamicResource OnAccentBrush}"
                            FontWeight="SemiBold"
                            Command="{Binding AddAudiobooksCommand}"
                            Content="Choose M4B files"
                            IsEnabled="{Binding CanAddAudiobooks}" />
                </StackPanel>
            </Border>

            <Grid IsVisible="{Binding HasLibraryBooks}">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding IsLibraryListView}">
                    <ItemsControl ItemsSource="{Binding LibraryBooks}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LibraryBookItemViewModel">
                            <Border Margin="0,0,0,10"
                                    Padding="16"
                                    CornerRadius="15"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <Grid ColumnDefinitions="58,*,Auto" ColumnSpacing="15">
                                    <Border Grid.Column="0"
                                            Width="58"
                                            Height="58"
                                            CornerRadius="12"
                                            Background="{DynamicResource ArtworkPlaceholderBrush}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding CoverImage}"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasCover}" />
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="25"
                                                       Foreground="{DynamicResource AccentTextBrush}"
                                                       IsVisible="{Binding HasNoCover}"
                                                       Text="♪" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center"
                                                Spacing="4">
                                        <TextBlock FontSize="16"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                                   Text="{Binding Title}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Text="{Binding AuthorText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="10"
                                                   Foreground="{DynamicResource AccentTextBrush}"
                                                   IsVisible="{Binding HasSeries}"
                                                   Text="{Binding SeriesText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <Border Padding="7,2"
                                                    CornerRadius="7"
                                                    Background="{DynamicResource AccentSoftBrush}">
                                                <TextBlock FontSize="9"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource AccentSoftTextBrush}"
                                                           Text="{Binding StorageModeText}" />
                                            </Border>
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       Text="{Binding FileSizeText}" />
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       Text="•" />
                                            <TextBlock VerticalAlignment="Center"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource MutedTextBrush}"
                                                       Text="{Binding ProgressSummary}" />
                                        </StackPanel>
                                        <TextBlock FontSize="10"
                                                   Foreground="{DynamicResource SubtleTextBrush}"
                                                   Text="{Binding FilePath}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2"
                                                MinWidth="104"
                                                VerticalAlignment="Center"
                                                Spacing="7">
                                        <TextBlock HorizontalAlignment="Center"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   Text="{Binding AvailabilityText}" />
                                        <Button Padding="16,8"
                                                Background="{DynamicResource AccentBrush}"
                                                Foreground="{DynamicResource OnAccentBrush}"
                                                FontWeight="SemiBold"
                                                Command="{Binding PlayCommand}"
                                                Content="Play"
                                                IsEnabled="{Binding IsAvailable}" />
                                        <Button Padding="12,7"
                                                Background="{DynamicResource SurfaceRaisedBrush}"
                                                Foreground="{DynamicResource SecondaryTextBrush}"
                                                FontSize="11"
                                                Command="{Binding EditMetadataCommand}"
                                                Content="{Binding DetailsButtonText}" />
                                        <Button Padding="12,7"
                                                Background="{DynamicResource SurfaceRaisedBrush}"
                                                Foreground="{DynamicResource SecondaryTextBrush}"
                                                FontSize="11"
                                                Command="{Binding ChooseCoverCommand}"
                                                Content="{Binding CoverButtonText}" />
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto"
                              IsVisible="{Binding IsLibraryTileView}">
                    <ItemsControl ItemsSource="{Binding LibraryBooks}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate x:DataType="vm:LibraryBookItemViewModel">
                            <Border Width="220"
                                    Margin="0,0,12,12"
                                    Padding="12"
                                    CornerRadius="16"
                                    Background="{DynamicResource SurfaceBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <Grid RowDefinitions="180,Auto,Auto,Auto,Auto,Auto,Auto" RowSpacing="9">
                                    <Border Grid.Row="0"
                                            CornerRadius="12"
                                            Background="{DynamicResource ArtworkPlaceholderBrush}"
                                            ClipToBounds="True">
                                        <Grid>
                                            <Image Source="{Binding CoverImage}"
                                                   Stretch="UniformToFill"
                                                   IsVisible="{Binding HasCover}" />
                                            <TextBlock HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       FontSize="54"
                                                       Foreground="{DynamicResource AccentTextBrush}"
                                                       IsVisible="{Binding HasNoCover}"
                                                       Text="♪" />
                                            <Border Margin="8"
                                                    Padding="7,3"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Top"
                                                    CornerRadius="7"
                                                    Background="{DynamicResource SurfaceAltBrush}">
                                                <TextBlock FontSize="9"
                                                           Foreground="{DynamicResource MutedTextBrush}"
                                                           Text="{Binding AvailabilityText}" />
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <TextBlock Grid.Row="1"
                                               Height="40"
                                               FontSize="15"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}"
                                               Text="{Binding Title}"
                                               TextTrimming="CharacterEllipsis"
                                               TextWrapping="Wrap" />

                                    <StackPanel Grid.Row="2" Spacing="2">
                                        <TextBlock FontSize="11"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   Text="{Binding AuthorText}"
                                                   TextTrimming="CharacterEllipsis" />
                                        <TextBlock FontSize="10"
                                                   Foreground="{DynamicResource AccentTextBrush}"
                                                   IsVisible="{Binding HasSeries}"
                                                   Text="{Binding SeriesText}"
                                                   TextTrimming="CharacterEllipsis" />
                                    </StackPanel>

                                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="7">
                                        <Border Padding="7,2"
                                                CornerRadius="7"
                                                Background="{DynamicResource AccentSoftBrush}">
                                            <TextBlock FontSize="9"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource AccentSoftTextBrush}"
                                                       Text="{Binding StorageModeText}" />
                                        </Border>
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="10"
                                                   Foreground="{DynamicResource MutedTextBrush}"
                                                   Text="{Binding FileSizeText}" />
                                    </StackPanel>

                                    <TextBlock Grid.Row="4"
                                               FontSize="11"
                                               Foreground="{DynamicResource AccentTextBrush}"
                                               Text="{Binding ProgressSummary}"
                                               TextTrimming="CharacterEllipsis" />

                                    <Button Grid.Row="5"
                                            Padding="12,8"
                                            Background="{DynamicResource AccentBrush}"
                                            Foreground="{DynamicResource OnAccentBrush}"
                                            FontWeight="SemiBold"
                                            Command="{Binding PlayCommand}"
                                            Content="Play"
                                            IsEnabled="{Binding IsAvailable}" />

                                    <Grid Grid.Row="6" ColumnDefinitions="*,*" ColumnSpacing="8">
                                        <Button Grid.Column="0"
                                                Padding="12,8"
                                                Background="{DynamicResource SurfaceRaisedBrush}"
                                                Foreground="{DynamicResource SecondaryTextBrush}"
                                                FontSize="10"
                                                Command="{Binding EditMetadataCommand}"
                                                Content="{Binding DetailsButtonText}" />
                                        <Button Grid.Column="1"
                                                Padding="9,8"
                                                Background="{DynamicResource SurfaceRaisedBrush}"
                                                Foreground="{DynamicResource SecondaryTextBrush}"
                                                FontSize="10"
                                                Command="{Binding ChooseCoverCommand}"
                                                Content="{Binding CoverButtonText}" />
                                    </Grid>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
