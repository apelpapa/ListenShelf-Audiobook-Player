<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ListenShelf.Desktop.ViewModels"
             x:Class="ListenShelf.Desktop.Views.Sections.PlayerView"
             x:DataType="vm:MainWindowViewModel">
    <Grid ColumnDefinitions="0.38*,0.62*" ColumnSpacing="22">
        <Border Grid.Column="0"
                Padding="22"
                CornerRadius="20"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid RowDefinitions="*,Auto">
                <Border Grid.Row="0"
                        MinHeight="240"
                        CornerRadius="17"
                        Background="{DynamicResource ArtworkPlaceholderBrush}"
                        ClipToBounds="True">
                    <Grid>
                        <Image Source="{Binding CurrentCoverImage}"
                               Stretch="Uniform"
                               IsVisible="{Binding HasCurrentCover}" />
                        <Border Width="104"
                                Height="104"
                                CornerRadius="52"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Background="{DynamicResource AccentSoftBrush}"
                                IsVisible="{Binding HasNoCurrentCover}">
                            <TextBlock HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       FontSize="42"
                                       Foreground="{DynamicResource AccentTextBrush}"
                                       Text="♪" />
                        </Border>
                    </Grid>
                </Border>

                <StackPanel Grid.Row="1" Margin="0,21,0,0" Spacing="7">
                    <TextBlock FontSize="21"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource PrimaryTextBrush}"
                               Text="{Binding BookTitle}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock FontSize="13"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Text="{Binding FileName}"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Margin="0,5,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource AccentTextBrush}"
                               Text="{Binding ProgressText}"
                               TextWrapping="Wrap" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Column="1"
                Padding="28"
                CornerRadius="20"
                Background="{DynamicResource SurfaceBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1">
            <Grid RowDefinitions="Auto,*,Auto">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto">
                    <StackPanel Spacing="5">
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   Text="NOW PLAYING" />
                        <TextBlock FontSize="17"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="{Binding StatusText}" />
                    </StackPanel>
                    <Border Grid.Column="1"
                            Padding="10,5"
                            VerticalAlignment="Top"
                            CornerRadius="10"
                            Background="{DynamicResource SurfaceRaisedBrush}">
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Text="M4B • LOCAL" />
                    </Border>
                </Grid>

                <StackPanel Grid.Row="1"
                            VerticalAlignment="Center"
                            Spacing="22">
                    <StackPanel Spacing="8">
                        <Slider Minimum="0"
                                Maximum="{Binding SeekMaximum}"
                                Value="{Binding PositionSeconds, Mode=TwoWay}"
                                IsEnabled="{Binding CanControlPlayback}" />
                        <Grid ColumnDefinitions="*,Auto,*">
                            <TextBlock Grid.Column="0"
                                       FontSize="12"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="{Binding ElapsedText}" />
                            <TextBlock Grid.Column="1"
                                       FontSize="12"
                                       Foreground="{DynamicResource SubtleTextBrush}"
                                       Text="{Binding DurationText}" />
                            <TextBlock Grid.Column="2"
                                       HorizontalAlignment="Right"
                                       FontSize="12"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="{Binding RemainingText}" />
                        </Grid>
                    </StackPanel>

                    <StackPanel HorizontalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="14">
                        <Button Width="92"
                                Height="48"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                Foreground="{DynamicResource SecondaryTextBrush}"
                                Command="{Binding SkipBackwardCommand}"
                                IsEnabled="{Binding CanControlPlayback}"
                                Content="−15 sec" />
                        <Button Width="112"
                                Height="56"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="{DynamicResource OnAccentBrush}"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Command="{Binding TogglePlaybackCommand}"
                                IsEnabled="{Binding CanControlPlayback}"
                                Content="{Binding PlayPauseLabel}" />
                        <Button Width="92"
                                Height="48"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                Foreground="{DynamicResource SecondaryTextBrush}"
                                Command="{Binding SkipForwardCommand}"
                                IsEnabled="{Binding CanControlPlayback}"
                                Content="+30 sec" />
                    </StackPanel>

                    <TextBlock MinHeight="20"
                               HorizontalAlignment="Center"
                               FontSize="12"
                               Foreground="{DynamicResource DangerTextBrush}"
                               Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <Grid Grid.Row="2" ColumnDefinitions="Auto,150,*,Auto,90">
                    <TextBlock Grid.Column="0"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="Volume" />
                    <Slider Grid.Column="1"
                            Minimum="0"
                            Maximum="100"
                            Value="{Binding Volume, Mode=TwoWay}" />

                    <TextBlock Grid.Column="3"
                               Margin="0,0,12,0"
                               VerticalAlignment="Center"
                               FontSize="13"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Text="Speed" />
                    <ComboBox Grid.Column="4"
                              ItemsSource="{Binding PlaybackRates}"
                              SelectedItem="{Binding SelectedPlaybackRate, Mode=TwoWay}" />
                </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
