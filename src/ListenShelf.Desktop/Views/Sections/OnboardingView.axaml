<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ListenShelf.Desktop.ViewModels"
             x:Class="ListenShelf.Desktop.Views.Sections.OnboardingView"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="860"
                    Margin="0,10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="18">
            <Image Width="76"
                   Height="76"
                   HorizontalAlignment="Center"
                   Source="/Assets/Branding/listenshelf-1024.png"
                   Stretch="Uniform" />
            <StackPanel Spacing="7">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="#F4F6FA"
                           Text="How should your library work?" />
                <TextBlock MaxWidth="650"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="#939EAF"
                           Text="Choose a starting preference. You can change this later, and ListenShelf will eventually support both styles side by side."
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                <Button Grid.Column="0"
                        Padding="0"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding ChooseLinkedLibraryCommand}">
                    <Border Padding="24"
                            CornerRadius="18"
                            Background="#171C26"
                            BorderBrush="#384256"
                            BorderThickness="1">
                        <StackPanel Spacing="11">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#F2A94E"
                                       Text="KEEP CONTROL" />
                            <TextBlock FontSize="19"
                                       FontWeight="SemiBold"
                                       Foreground="#F1F3F7"
                                       Text="Keep files where they are" />
                            <TextBlock FontSize="12"
                                       Foreground="#929DAF"
                                       Text="ListenShelf links to your existing audiobooks. It remembers their locations but never rearranges your folders."
                                       TextWrapping="Wrap" />
                            <Border Height="1" Margin="0,4" Background="#2A3241" />
                            <TextBlock FontSize="11"
                                       Foreground="#C0C8D5"
                                       Text="Best for carefully organized folders and external drives."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Button>

                <Button Grid.Column="1"
                        Padding="0"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding ChooseManagedLibraryCommand}">
                    <Border Padding="24"
                            CornerRadius="18"
                            Background="#171C26"
                            BorderBrush="#384256"
                            BorderThickness="1">
                        <StackPanel Spacing="11">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#E7654B"
                                       Text="LET LISTENSHELF HANDLE IT" />
                            <TextBlock FontSize="19"
                                       FontWeight="SemiBold"
                                       Foreground="#F1F3F7"
                                       Text="Manage copies for me" />
                            <TextBlock FontSize="12"
                                       Foreground="#929DAF"
                                       Text="ListenShelf will copy future imports into its own library and take care of organization behind the scenes."
                                       TextWrapping="Wrap" />
                            <Border Height="1" Margin="0,4" Background="#2A3241" />
                            <TextBlock FontSize="11"
                                       Foreground="#C0C8D5"
                                       Text="Best for a hands-off, application-managed collection."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Button>
            </Grid>

            <TextBlock HorizontalAlignment="Center"
                       FontSize="11"
                       Foreground="#6E798B"
                       Text="This choice saves a preference only. No files are touched during setup." />
            <TextBlock HorizontalAlignment="Center"
                       FontSize="11"
                       Foreground="#FF8A98"
                       IsVisible="{Binding HasLibrarySettingsError}"
                       Text="{Binding LibrarySettingsErrorMessage}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
