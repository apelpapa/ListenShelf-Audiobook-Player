<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:ListenShelf.Desktop.ViewModels"
             x:Class="ListenShelf.Desktop.Views.Sections.OnboardingView"
             x:DataType="vm:MainWindowViewModel">
    <ScrollViewer HorizontalScrollBarVisibility="Disabled">
        <StackPanel MaxWidth="860"
                    Margin="0,10"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="18">
            <Image Width="76"
                   Height="76"
                   HorizontalAlignment="Center"
                   Source="/Assets/Branding/listenshelf-1024.png"
                   Stretch="Uniform" />
            <StackPanel Spacing="7">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="28"
                           FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}"
                           Text="How should your library work?" />
                <TextBlock MaxWidth="650"
                           HorizontalAlignment="Center"
                           FontSize="13"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Text="Choose a starting preference for future imports. You can change it later in Settings."
                           TextAlignment="Center"
                           TextWrapping="Wrap" />
            </StackPanel>

            <Grid ColumnDefinitions="*,*" ColumnSpacing="18">
                <Button Grid.Column="0"
                        Padding="0"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding ChooseLinkedLibraryCommand}">
                    <Border Padding="24"
                            CornerRadius="18"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderStrongBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="11">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource WarmAccentBrush}"
                                       Text="PLAYER ONLY" />
                            <TextBlock FontSize="19"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="Player Only Mode" />
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="ListenShelf remembers where your files are and saves each listening position, but does not manage copies or editable book metadata."
                                       TextWrapping="Wrap" />
                            <Border Height="1" Margin="0,4" Background="{DynamicResource SeparatorBrush}" />
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="Best when you only want playback and progress tracking."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Button>

                <Button Grid.Column="1"
                        Padding="0"
                        HorizontalContentAlignment="Stretch"
                        VerticalContentAlignment="Stretch"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding ChooseManagedLibraryCommand}">
                    <Border Padding="24"
                            CornerRadius="18"
                            Background="{DynamicResource SurfaceBrush}"
                            BorderBrush="{DynamicResource BorderStrongBrush}"
                            BorderThickness="1">
                        <StackPanel Spacing="11">
                            <TextBlock FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource CoralAccentBrush}"
                                       Text="LET LISTENSHELF HANDLE IT" />
                            <TextBlock FontSize="19"
                                       FontWeight="SemiBold"
                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                       Text="Manage copies for me" />
                            <TextBlock FontSize="12"
                                       Foreground="{DynamicResource MutedTextBrush}"
                                       Text="ListenShelf will copy future imports into its own library and take care of organization behind the scenes."
                                       TextWrapping="Wrap" />
                            <Border Height="1" Margin="0,4" Background="{DynamicResource SeparatorBrush}" />
                            <TextBlock FontSize="11"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       Text="Best for a hands-off, application-managed collection."
                                       TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Button>
            </Grid>

            <TextBlock HorizontalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource SubtleTextBrush}"
                       Text="This choice saves a preference only. No files are touched during setup." />
            <TextBlock HorizontalAlignment="Center"
                       FontSize="11"
                       Foreground="{DynamicResource DangerTextBrush}"
                       IsVisible="{Binding HasLibrarySettingsError}"
                       Text="{Binding LibrarySettingsErrorMessage}"
                       TextWrapping="Wrap" />
        </StackPanel>
    </ScrollViewer>
</UserControl>
