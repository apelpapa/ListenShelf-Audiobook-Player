<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ListenShelf.Desktop.ViewModels"
        xmlns:sections="using:ListenShelf.Desktop.Views.Sections"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1180"
        d:DesignHeight="720"
        x:Class="ListenShelf.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        Background="{DynamicResource AppBackgroundBrush}"
        Icon="/Assets/Branding/listenshelf.ico"
        Title="{Binding WindowTitle}">

    <Window.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Padding" Value="12,11" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{DynamicResource NavigationTextBrush}" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="{DynamicResource NavigationHoverBrush}" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="220,*">
        <Border Grid.Column="0"
                Padding="18"
                Background="{DynamicResource SidebarBackgroundBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,Auto,*">
                <StackPanel Grid.Row="0"
                            Margin="4,4,4,28"
                            Orientation="Horizontal"
                            Spacing="12">
                    <Image Width="40"
                           Height="40"
                           Stretch="Uniform"
                           Source="/Assets/Branding/listenshelf-1024.png"
                           AutomationProperties.Name="ListenShelf logo" />
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="ListenShelf" />
                        <TextBlock FontSize="10"
                                   Foreground="{DynamicResource SubtleTextBrush}"
                                   Text="AUDIOBOOK PLAYER" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="5">
                    <Button Classes="nav"
                            Command="{Binding ShowLibraryCommand}"
                            IsVisible="{Binding IsPersistentSession}">
                        <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    CornerRadius="2"
                                    Background="{DynamicResource AccentBrush}"
                                    IsVisible="{Binding IsLibrarySection}" />
                            <TextBlock Grid.Column="1"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="Library" />
                        </Grid>
                    </Button>
                    <Button Classes="nav" Command="{Binding ShowPlayerCommand}">
                        <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    CornerRadius="2"
                                    Background="{DynamicResource AccentBrush}"
                                    IsVisible="{Binding IsPlayerSection}" />
                            <TextBlock Grid.Column="1"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="Player" />
                        </Grid>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0"
                    Padding="28,19"
                    Background="{DynamicResource HeaderBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="3">
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   Text="{Binding PageTitle}" />
                        <TextBlock FontSize="12"
                                   Foreground="{DynamicResource MutedTextBrush}"
                                   Text="{Binding PageSubtitle}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                Orientation="Horizontal"
                                Spacing="10">
                        <Button Padding="20,11"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="{DynamicResource OnAccentBrush}"
                                FontWeight="SemiBold"
                                Command="{Binding AddAudiobooksCommand}"
                                Content="Add audiobooks"
                                IsEnabled="{Binding CanAddAudiobooks}"
                                IsVisible="{Binding IsLibrarySection}" />
                        <Button Padding="20,11"
                                Background="{DynamicResource AccentBrush}"
                                Foreground="{DynamicResource OnAccentBrush}"
                                FontWeight="SemiBold"
                                Command="{Binding OpenFileCommand}"
                                Content="Open audiobook"
                                IsVisible="{Binding IsPlayerSection}" />
                        <Button Width="40"
                                Height="40"
                                Padding="0"
                                Background="{DynamicResource SurfaceRaisedBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                Command="{Binding ShowSettingsCommand}"
                                IsEnabled="{Binding IsMainContentVisible}"
                                IsVisible="{Binding IsPersistentSession}"
                                ToolTip.Tip="Settings">
                            <Grid>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="19"
                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                           Text="⚙" />
                                <Border Width="16"
                                        Height="3"
                                        Margin="0,0,0,4"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Bottom"
                                        Background="{DynamicResource AccentBrush}"
                                        CornerRadius="2"
                                        IsVisible="{Binding IsSettingsSection}" />
                            </Grid>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="26">
                <sections:OnboardingView IsVisible="{Binding IsOnboardingVisible}" />

                <Grid IsVisible="{Binding IsMainContentVisible}">
                    <sections:LibraryView IsVisible="{Binding IsLibrarySection}" />
                    <sections:PlayerView IsVisible="{Binding IsPlayerSection}" />
                    <sections:SettingsView IsVisible="{Binding IsSettingsSection}" />
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Padding="24,10"
                    Background="{DynamicResource FooterBackgroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="11"
                           Foreground="{DynamicResource SubtleTextBrush}"
                           Text="{Binding FooterText}" />
            </Border>
        </Grid>
    </Grid>
</Window>
