<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:ListenShelf.Desktop.ViewModels"
        xmlns:sections="using:ListenShelf.Desktop.Views.Sections"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1180"
        d:DesignHeight="720"
        x:Class="ListenShelf.Desktop.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Width="1180"
        Height="720"
        MinWidth="980"
        MinHeight="620"
        Background="#0E1118"
        Icon="/Assets/Branding/listenshelf.ico"
        Title="ListenShelf — Audiobook Player">

    <Window.Styles>
        <Style Selector="Button.nav">
            <Setter Property="Padding" Value="12,11" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="#B5BECE" />
            <Setter Property="CornerRadius" Value="10" />
        </Style>
        <Style Selector="Button.nav:pointerover /template/ ContentPresenter">
            <Setter Property="Background" Value="#202635" />
        </Style>
    </Window.Styles>

    <Grid ColumnDefinitions="220,*">
        <Border Grid.Column="0"
                Padding="18"
                Background="#121722"
                BorderBrush="#242B38"
                BorderThickness="0,0,1,0">
            <Grid RowDefinitions="Auto,Auto,*,Auto">
                <StackPanel Grid.Row="0"
                            Margin="4,4,4,28"
                            Orientation="Horizontal"
                            Spacing="12">
                    <Image Width="40"
                           Height="40"
                           Stretch="Uniform"
                           Source="/Assets/Branding/listenshelf-1024.png"
                           AutomationProperties.Name="ListenShelf logo" />
                    <StackPanel VerticalAlignment="Center" Spacing="1">
                        <TextBlock FontSize="18"
                                   FontWeight="SemiBold"
                                   Foreground="#F5F7FB"
                                   Text="ListenShelf" />
                        <TextBlock FontSize="10"
                                   Foreground="#7F899B"
                                   Text="AUDIOBOOK PLAYER" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Row="1" Spacing="5">
                    <Button Classes="nav" Command="{Binding ShowLibraryCommand}">
                        <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    CornerRadius="2"
                                    Background="#7567F8"
                                    IsVisible="{Binding IsLibrarySection}" />
                            <TextBlock Grid.Column="1"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="Library" />
                        </Grid>
                    </Button>
                    <Button Classes="nav" Command="{Binding ShowPlayerCommand}">
                        <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    CornerRadius="2"
                                    Background="#7567F8"
                                    IsVisible="{Binding IsPlayerSection}" />
                            <TextBlock Grid.Column="1"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="Player" />
                        </Grid>
                    </Button>
                    <Button Classes="nav" Command="{Binding ShowSettingsCommand}">
                        <Grid ColumnDefinitions="4,*" ColumnSpacing="12">
                            <Border Grid.Column="0"
                                    CornerRadius="2"
                                    Background="#7567F8"
                                    IsVisible="{Binding IsSettingsSection}" />
                            <TextBlock Grid.Column="1"
                                       FontSize="14"
                                       FontWeight="SemiBold"
                                       Text="Settings" />
                        </Grid>
                    </Button>
                </StackPanel>

                <Border Grid.Row="3"
                        Padding="13"
                        CornerRadius="12"
                        Background="#181E2A"
                        BorderBrush="#272F3E"
                        BorderThickness="1">
                    <StackPanel Spacing="5">
                        <TextBlock FontSize="10"
                                   FontWeight="SemiBold"
                                   Foreground="#7F899C"
                                   Text="LIBRARY MODE" />
                        <TextBlock FontSize="12"
                                   FontWeight="SemiBold"
                                   Foreground="#DCE1EA"
                                   Text="{Binding CurrentLibraryModeTitle}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto">
            <Border Grid.Row="0"
                    Padding="28,19"
                    Background="#141923"
                    BorderBrush="#242B38"
                    BorderThickness="0,0,0,1">
                <Grid ColumnDefinitions="*,Auto">
                    <StackPanel Grid.Column="0" Spacing="3">
                        <TextBlock FontSize="22"
                                   FontWeight="SemiBold"
                                   Foreground="#F5F7FB"
                                   Text="{Binding PageTitle}" />
                        <TextBlock FontSize="12"
                                   Foreground="#8F99AA"
                                   Text="{Binding PageSubtitle}" />
                    </StackPanel>

                    <Button Grid.Column="1"
                            Padding="20,11"
                            VerticalAlignment="Center"
                            Background="#7567F8"
                            Foreground="White"
                            FontWeight="SemiBold"
                            Command="{Binding OpenFileCommand}"
                            Content="Open M4B"
                            IsVisible="{Binding IsPlayerSection}" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" Margin="26">
                <sections:OnboardingView IsVisible="{Binding IsOnboardingVisible}" />

                <Grid IsVisible="{Binding IsMainContentVisible}">
                    <sections:LibraryView IsVisible="{Binding IsLibrarySection}" />
                    <sections:PlayerView IsVisible="{Binding IsPlayerSection}" />
                    <sections:SettingsView IsVisible="{Binding IsSettingsSection}" />
                </Grid>
            </Grid>

            <Border Grid.Row="2"
                    Padding="24,10"
                    Background="#111620"
                    BorderBrush="#242B38"
                    BorderThickness="0,1,0,0">
                <TextBlock HorizontalAlignment="Center"
                           FontSize="11"
                           Foreground="#6F798A"
                           Text="Offline playback • Settings alone never move or copy your files" />
            </Border>
        </Grid>
    </Grid>
</Window>
